# ==============================================
# HelpDesk Project - Common .gitignore
# ==============================================

# ======================
# OS Files
# ======================
.DS_Store
Thumbs.db
*.tmp

# ======================
# IDE & Editors
# ======================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ======================
# Environment Files
# ======================

# ======================
# Logs
# ======================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ======================
# Python (Backend)
# ======================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ======================
# Node.js (Frontend)
# ======================
node_modules/
dist/
dist-ssr/
*.local

# Bun
bun.lockb

# ======================
# Docker & Deployment
# ======================
# SSL certificates (generated by certbot)
certbot/
# SSL private keys and certs (Namecheap Positive SSL)
nginx/ssl/
# DCV validation files (temporary)
nginx/well-known/*
!nginx/well-known/.gitkeep
!nginx/well-known/pki-validation/
nginx/well-known/pki-validation/*
!nginx/well-known/pki-validation/.gitkeep

# ======================
# Claude Code (local, machine-specific)
# ======================
.claude/settings.local.json

# ======================
# TypeScript build cache
# ======================
*.tsbuildinfo

# ======================
# Reference-only project (FaceID/bnpzID integration reference — NOT part of this repo)
# ======================
employee_service/

# ======================
# Project Specific
# ======================
# Env templates (.env.local.example, .env.prod.example) are kept in repo
