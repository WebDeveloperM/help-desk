# ==============================================
# HelpDesk — Production (.env.prod)
# ==============================================
# cp .env.prod.example .env.prod && edit .env.prod
# Запуск на VPS: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# Keycloak: realm helpdesk, client helpdesk-backend (confidential).
# Полная инструкция по развёртыванию: docs/DEPLOY_VPS.md
# Настройка Keycloak realm и клиента: docs/KEYCLOAK_SETUP.md
# ==============================================
#
# ВАЖНО: все «public» URL ниже должны указывать на адрес, по которому
# пользователи открывают приложение. По умолчанию шаблон настроен на
# http://195.158.14.125:36631 (HTTP, нестандартный порт). Порт ОБЯЗАН входить
# во все public URL — без него редирект на Keycloak уходит на :80 и падает.
# Когда появится домен и SSL — замените на https://<domain>.
#
# Пароли ниже заданы рабочими значениями по умолчанию, чтобы стенд поднимался
# сразу после `cp .env.prod.example .env.prod`. Для реального публичного прода
# ОБЯЗАТЕЛЬНО смените их на собственные (только буквы/цифры/подчёркивание).
# ==============================================

# ------------------------------
# PostgreSQL (основная БД приложения)
# ------------------------------
# ВАЖНО: POSTGRES_PASSWORD ниже и пароль внутри DATABASE_URL должны совпадать
# ПОСИМВОЛЬНО. Меняешь здесь — поменяй и в DATABASE_URL.
# Пароль применяется к БД только при ПЕРВОЙ инициализации volume
# helpdesk_postgres_data. Если меняешь пароль на уже запускавшемся стенде —
# пересоздай volume (docker volume rm helpdesk_postgres_data) или сделай ALTER USER.
# Используй только буквы/цифры/подчёркивание: символы @ : / # ? % в DATABASE_URL
# пришлось бы URL-кодировать.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=helpdesk_db_pwd
POSTGRES_DB=helpdesk

# ------------------------------
# Backend (FastAPI)
# ------------------------------
DEBUG=false
# Пароль здесь обязан совпадать с POSTGRES_PASSWORD выше (см. предупреждение в секции PostgreSQL).
DATABASE_URL=postgresql+asyncpg://postgres:helpdesk_db_pwd@db:5432/helpdesk
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis для PKCE verifier store. Обязателен в production: без него multi-worker uvicorn
# даёт pkce_expired при логине, потому что workers не разделяют in-memory state.
REDIS_URL=redis://redis:6379/0

# ------------------------------
# RabbitMQ (опционально — outbox dispatcher для уведомлений)
# ------------------------------
# Если не задано — outbox dispatcher не запускается, уведомления остаются в БД,
# но не публикуются. Когда понадобится доставка — поднимите rabbitmq как сервис
# и раскомментируйте URL.
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ------------------------------
# Keycloak — БД и админ (для docker-compose.prod.yml)
# ------------------------------
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=helpdesk_kc_db_pwd
KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD обязателен: без него bootstrap-админ не создаётся при первом старте
KEYCLOAK_ADMIN_PASSWORD=helpdesk_kc_admin_pwd
# Публичный URL Keycloak (без пути; nginx проксирует /realms/ и /admin/).
# Если KEYCLOAK_ISSUER не задан, бэкенд соберёт его из KEYCLOAK_PUBLIC_URL.
KEYCLOAK_PUBLIC_URL=http://195.158.14.125:36631

# ------------------------------
# Keycloak — confidential client для BFF (бэкенд)
# ------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=helpdesk
KEYCLOAK_CLIENT_ID=helpdesk-backend
KEYCLOAK_CLIENT_SECRET=<secret from Keycloak Credentials, see docs/DEPLOY_VPS.md>
KEYCLOAK_AUDIENCE=

# Service-account клиент для записи user attributes (department_id, department_number) через Admin API.
# Рекомендуется отдельный клиент helpdesk-admin со service accounts ON и ролями
# realm-management → view-users + manage-users. Если оба значения пусты — бэкенд
# возьмёт KEYCLOAK_CLIENT_ID/SECRET (нужны service accounts на BFF-клиенте).
# Подробнее: docs/KEYCLOAK_SETUP.md, раздел 5.1.
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
# Keycloak 17+: issuer path is /realms/{realm} only (no /auth prefix)
KEYCLOAK_ISSUER=http://195.158.14.125:36631/realms/helpdesk

# BFF auth redirects (обязательны)
FRONTEND_URL=http://195.158.14.125:36631
AUTH_CALLBACK_URL=http://195.158.14.125:36631/api/v1/auth/callback

# CORS: ровно те origins, по которым пользователи открывают приложение.
ALLOWED_CORS_ORIGINS=http://195.158.14.125:36631

# ------------------------------
# Frontend build (только VITE_API_URL — встраивается в bundle при сборке)
# ------------------------------
VITE_API_URL=/api/v1

# ------------------------------
# MinIO (asset images)
# ------------------------------
# Root credentials — задаются один раз при первом старте контейнера. Меняются только
# через `mc admin user` или пересозданием volume. Используйте надёжные значения.
MINIO_ROOT_USER=helpdesk_minio
MINIO_ROOT_PASSWORD=helpdesk_minio_pwd
# Эти ключи использует backend для S3 API. На старте используем root creds —
# значения должны совпадать с MINIO_ROOT_USER / MINIO_ROOT_PASSWORD выше.
# Позже для prod можно создать отдельного пользователя/access key через mc admin.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=helpdesk_minio
MINIO_SECRET_KEY=helpdesk_minio_pwd
MINIO_BUCKET_NAME=assets
MINIO_SECURE=false
MINIO_REGION=
# Публичная ссылка, по которой браузер забирает изображения. nginx проксирует
# /media/ → minio:9000 (см. nginx/nginx.conf), порт 9000 на хост НЕ публикуется.
# Суффикс /media обязателен — итоговый URL картинки получится
# {MINIO_PUBLIC_BASE_URL}/{bucket}/{object}. Префикс /assets использовать НЕЛЬЗЯ:
# по нему ходят JS/CSS-бандлы Vite-фронта.
MINIO_PUBLIC_BASE_URL=http://195.158.14.125:36631/media
